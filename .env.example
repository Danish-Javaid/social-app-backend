# Database
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/social_media_dev

# Debug mode
DEBUG=True

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256

# Cookie settings (httpOnly access/refresh token cookies)
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/oauth/github/callback

FRONTEND_URL=http://localhost:3000

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Social Media App

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=social-media-app-eashal-12345